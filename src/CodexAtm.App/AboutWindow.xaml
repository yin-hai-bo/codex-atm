<Window x:Class="CodexAtm.App.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CodexAtm.App"
        mc:Ignorable="d"
        Title="{Binding WindowTitle, RelativeSource={RelativeSource Self}}"
        Width="680"
        Height="420"
        MinWidth="680"
        MinHeight="420"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Icon="Assets/CodexAtmIcon.ico"
        Background="Transparent">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ButtonBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource ButtonForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource ButtonHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource ButtonPressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Hyperlink">
            <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
            <Setter Property="TextDecorations" Value="Underline" />
        </Style>

        <Style x:Key="ClickableTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="TextDecorations" Value="Underline" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid" Margin="18" Background="Transparent">
        <Border Padding="24"
                Background="{DynamicResource AboutSurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="20" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="20" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Width="80"
                            Height="80"
                            Background="{DynamicResource AccentSurfaceBrush}"
                            CornerRadius="20">
                        <Image Width="64"
                               Height="64"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               SnapsToDevicePixels="True"
                               UseLayoutRounding="True"
                               Source="Assets/CodexAtmIconAbout.png" />
                    </Border>

                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Text="{Binding ProductName, RelativeSource={RelativeSource AncestorType=Window}}" />
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Text="{Binding AboutWindowDescription, RelativeSource={RelativeSource AncestorType=Window}}" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="2" Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Text="{Binding VersionLabel, RelativeSource={RelativeSource AncestorType=Window}}" />
                    <TextBlock Grid.Column="1"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Text="{Binding DisplayVersion, Mode=OneWay}" />

                    <TextBlock Grid.Row="2"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Text="{Binding GitCommitIdLabel, RelativeSource={RelativeSource AncestorType=Window}}" />
                    <TextBlock Grid.Row="2"
                               Grid.Column="1"
                               VerticalAlignment="Center"
                               FontFamily="Consolas"
                               Style="{StaticResource ClickableTextStyle}"
                               MouseLeftButtonUp="CommitId_MouseLeftButtonUp"
                               ToolTip="{Binding CopyOnClickToolTip, RelativeSource={RelativeSource AncestorType=Window}}"
                               Text="{Binding CommitId, Mode=OneWay}" />

                    <TextBlock Grid.Row="4"
                               VerticalAlignment="Top"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Text="{Binding RepositoryLabel, RelativeSource={RelativeSource AncestorType=Window}}" />
                    <TextBlock Grid.Row="4"
                               Grid.Column="1"
                               VerticalAlignment="Top"
                               TextWrapping="Wrap">
                        <Hyperlink NavigateUri="{Binding RepositoryUrl}"
                                   RequestNavigate="RepositoryLink_RequestNavigate">
                            <Run Text="{Binding RepositoryUrl, Mode=OneWay}" />
                        </Hyperlink>
                    </TextBlock>
                </Grid>

                <Button Grid.Row="4"
                        Width="96"
                        Padding="12,8"
                        HorizontalAlignment="Right"
                        IsDefault="True"
                        IsCancel="True"
                        Click="CloseButton_Click"
                        Content="{Binding CloseButtonText, RelativeSource={RelativeSource AncestorType=Window}}" />
            </Grid>
        </Border>

        <Border x:Name="ToastBorder"
                Panel.ZIndex="1"
                Padding="14,8"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Background="{DynamicResource TextPrimaryBrush}"
                CornerRadius="10"
                Opacity="0"
                Visibility="Collapsed">
            <TextBlock x:Name="ToastText"
                       Foreground="{DynamicResource SurfaceBrush}"
                       Text="{Binding DefaultToastText, RelativeSource={RelativeSource AncestorType=Window}}" />
        </Border>
    </Grid>
</Window>
