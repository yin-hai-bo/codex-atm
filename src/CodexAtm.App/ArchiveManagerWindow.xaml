<Window x:Class="CodexAtm.App.ArchiveManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CodexAtm.App"
        xmlns:model="clr-namespace:CodexAtm.Core.Models;assembly=CodexAtm.Core"
        mc:Ignorable="d"
        Title="Codex 归档线程管理器"
        Width="1360"
        Height="860"
        MinWidth="1100"
        MinHeight="720"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <local:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <local:NullToVisibilityConverter x:Key="InverseNullToVisibilityConverter" Invert="True" />
    </Window.Resources>

    <Grid Background="#F4F6FB">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Margin="20,20,20,12"
                Padding="20"
                Background="White"
                BorderBrush="#D8DFEB"
                BorderThickness="1"
                CornerRadius="16">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="#1F2937"
                               Text="Codex 归档线程管理器" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="#52607A"
                               Text="查看、预览并删除本机 Codex App 的归档线程" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBox Width="320"
                             Margin="0,0,12,0"
                             Padding="10,6"
                             VerticalContentAlignment="Center"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Width="110"
                            Padding="12,8"
                            Command="{Binding RefreshCommand}"
                            Content="刷新列表" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="20,0,20,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="12"
                    Background="White"
                    BorderBrush="#D8DFEB"
                    BorderThickness="1"
                    CornerRadius="16">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Margin="4,4,4,12"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#1F2937"
                               Text="归档列表" />
                    <ListView ItemsSource="{Binding Sessions}"
                              SelectedItem="{Binding SelectedSession, Mode=TwoWay}"
                              BorderThickness="0"
                              Background="Transparent"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemTemplate>
                            <DataTemplate DataType="{x:Type model:ArchiveSessionSummary}">
                                <Border Margin="0,0,0,10"
                                        Padding="14"
                                        Background="#F8FAFD"
                                        BorderBrush="#E3E9F3"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{Binding DisplayTitle}"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="#18212F"
                                                   TextTrimming="CharacterEllipsis" />
                                        <Border Grid.Column="1"
                                                Padding="8,4"
                                                Background="#E8EEF8"
                                                CornerRadius="999">
                                            <TextBlock Foreground="#294C7A"
                                                       Text="{Binding ParseStatus}" />
                                        </Border>

                                        <TextBlock Grid.Row="1"
                                                   Grid.ColumnSpan="2"
                                                   Margin="0,8,0,0"
                                                   Foreground="#52607A"
                                                   Text="{Binding Cwd}"
                                                   TextTrimming="CharacterEllipsis" />

                                        <Grid Grid.Row="2" Grid.ColumnSpan="2" Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Foreground="#6B7280"
                                                       Text="{Binding FileName}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="1"
                                                       Margin="12,0,0,0"
                                                       Foreground="#6B7280"
                                                       Text="{Binding DisplayFileSize}" />
                                            <TextBlock Grid.Column="2"
                                                       Margin="12,0,0,0"
                                                       Foreground="#6B7280"
                                                       Text="{Binding LastWriteTime}" />
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </DockPanel>
            </Border>

            <Border Grid.Column="2"
                    Padding="18"
                    Background="White"
                    BorderBrush="#D8DFEB"
                    BorderThickness="1"
                    CornerRadius="16">
                <Grid>
                    <Grid Visibility="{Binding SelectedSessionDetail, Converter={StaticResource InverseNullToVisibilityConverter}}">
                        <TextBlock VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Foreground="#6B7280"
                                   Text="选择左侧归档线程后，这里会显示元信息与最近几条消息。" />
                    </Grid>

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding SelectedSessionDetail, Converter={StaticResource NullToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#1F2937"
                                       Text="详情预览" />

                            <Border Margin="0,14,0,16"
                                    Padding="14"
                                    Background="#F8FAFD"
                                    BorderBrush="#E3E9F3"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Foreground="#52607A" Text="线程 ID" />
                                    <TextBlock Grid.Column="1" Text="{Binding SelectedSessionDetail.Summary.SessionId}" TextWrapping="Wrap" />

                                    <TextBlock Grid.Row="1" Foreground="#52607A" Text="文件路径" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedSessionDetail.Summary.FilePath}" TextWrapping="Wrap" />

                                    <TextBlock Grid.Row="2" Foreground="#52607A" Text="工作目录" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedSessionDetail.Summary.Cwd}" TextWrapping="Wrap" />

                                    <TextBlock Grid.Row="3" Foreground="#52607A" Text="修改时间" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedSessionDetail.Summary.LastWriteTime}" />

                                    <TextBlock Grid.Row="4" Foreground="#52607A" Text="文件大小" />
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedSessionDetail.Summary.DisplayFileSize}" />

                                    <TextBlock Grid.Row="5" Foreground="#52607A" Text="来源" />
                                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SelectedSessionDetail.Source}" />

                                    <TextBlock Grid.Row="6" Foreground="#52607A" Text="Originator" />
                                    <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding SelectedSessionDetail.Originator}" />

                                    <TextBlock Grid.Row="7" Foreground="#52607A" Text="CLI Version" />
                                    <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding SelectedSessionDetail.CliVersion}" />
                                </Grid>
                            </Border>

                            <TextBlock FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#1F2937"
                                       Text="最近几条消息" />

                            <ItemsControl Margin="0,12,0,0"
                                          ItemsSource="{Binding SelectedSessionDetail.Messages}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type model:ArchiveSessionMessage}">
                                        <Border Margin="0,0,0,10"
                                                Padding="12"
                                                Background="#FBFCFE"
                                                BorderBrush="#E3E9F3"
                                                BorderThickness="1"
                                                CornerRadius="12">
                                            <StackPanel>
                                                <DockPanel>
                                                    <TextBlock FontWeight="SemiBold"
                                                               Foreground="#294C7A"
                                                               Text="{Binding Role}" />
                                                    <TextBlock DockPanel.Dock="Right"
                                                               Foreground="#6B7280"
                                                               Text="{Binding Timestamp}" />
                                                </DockPanel>
                                                <TextBlock Margin="0,8,0,0"
                                                           Text="{Binding Content}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Margin="20,0,20,20"
                Padding="16,12"
                Background="White"
                BorderBrush="#D8DFEB"
                BorderThickness="1"
                CornerRadius="16">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal">
                    <Button Width="130"
                            Margin="0,0,12,0"
                            Padding="12,8"
                            Click="RecycleSelectedSession_Click"
                            Content="移到回收站"
                            IsEnabled="{Binding CanDeleteSelectedSession}" />
                    <Button Width="130"
                            Padding="12,8"
                            Background="#A61E2F"
                            Foreground="White"
                            Click="DeleteSelectedSession_Click"
                            Content="永久删除"
                            IsEnabled="{Binding CanDeleteSelectedSession}" />
                </StackPanel>

                <TextBlock VerticalAlignment="Center"
                           Foreground="#52607A"
                           Text="{Binding StatusText}" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
